{
  "buildCommand": "cd performance-dashboard/frontend && npm install --legacy-peer-deps && npm run build",
  "outputDirectory": "performance-dashboard/frontend/dist",
  "installCommand": "echo 'skip root install'",
  "rewrites": [
    { "source": "/health", "destination": "/api/index" },
    { "source": "/api/:path*", "destination": "/api/index" }
  ]
}
